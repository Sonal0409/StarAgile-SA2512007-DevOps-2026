WORDPRESS_MYSQL DEMO

# vim docker-compose.yml

# create a custom bridge network with name mynet1
networks:
  mynet1:
# create a named volume to preserve data
volumes:
  myvol:
# Deploy microservices
# docker run --name=db -e MYSQL_ROOT_PASSWORD=password --network=mynet1 -v=myvol:/var/lib/mysql mysql
services:
  db:
   image: mysql
   networks:
     - mynet1
   environment:
     MYSQL_ROOT_PASSWORD: password
     MYSQL_DATABASE: wordpress
     MYSQL_USER: wordpress
     MYSQL_PASSWORD: wordpress
   volumes:
     - myvol:/var/lib/mysql
   restart: always
# docker run --name=myweb -p 8282:80 --network=mynet1 -e WORDPRESS_DB_NAME=wordpress  wordpress
  myweb:
    depends_on:
      - db
    image: wordpress
    networks:
      - mynet1
    ports:
      - 8282:80
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_NAME: wordpress
      WORDPRESS_DB_USER: wordpress
      WORDPRESS_DB_PASSWORD: wordpress


